################
#              #
#   ZSH ENV    #
#              #
################

if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
    source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Path to your oh-my-zsh installation.
export ZSH="${HOME}/.oh-my-zsh"

ZSH_THEME="powerlevel10k/powerlevel10k"


HIST_STAMPS="mm/dd/yyyy"

{{- if eq .chezmoi.os "linux" }}
plugins=(git fzf ansible aws direnv podman docker-compose iterm2 terraform tmux kubectl gcloud vagrant zsh-syntax-highlighting z kubectx)
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
plugins=(git fzf ansible brew aws direnv podman docker-compose iterm2 terraform tmux kubectl gcloud vagrant zsh-syntax-highlighting z kubectx)
{{- end }}

source $ZSH/oh-my-zsh.sh

# User configuration
# Common

[[ -f ${HOME}/.p10k.zsh ]] && source ${HOME}/.p10k.zsh
[[ -f ${HOME}/.fzf.zsh ]] && source ${HOME}/.fzf.zsh
[[ -f $(brew --prefix)/etc/brew-wrap ]] && source $(brew --prefix)/etc/brew-wrap
[[ -f ${HOME}/.zsh/extract.plugin.zsh ]] && source ${HOME}/.zsh/extract.plugin.zsh

bindkey "^[[1;3C" forward-word
bindkey "^[[1;3D" backward-word

eval "$(pyenv init -)"
eval "$(direnv hook zsh)"

command -v pyenv >/dev/null || export PATH="${PYENV_ROOT}/bin:${PATH}"

export AZURE_DEV_COLLECT_TELEMETRY="no"
export PAGER="cat"
export PATH="${PATH}:/usr/local/sbin:/home/linuxbrew/.linuxbrew/bin:/${HOME}/.local/bin:$HOME/bin:${HOME}/.bin/:${HOME}/.azure/bin"
export PYENV_ROOT="${HOME}/.pyenv"
export GOPATH="${HOME}/.go"
export LESS="-F -X ${LESS}"
export LS_COLORS="$(vivid generate snazzy)"
alias j="z"
alias vim="nvim"
alias hg='history | grep '

### GCP ###

function gproject {
    select gcp_project in $(
        gcloud projects list --format json | jq -r '.[] | .projectId' ); do
            gcloud config set project $gcp_project
            echo "Active GCP Project : $gcp_project"
    break
    done
}

function glogin {
    CRED_PATH="${HOME}/.config/gcloud/creds/sa/"
    select creds in $(gfind ${CRED_PATH} -type f ); do
        export GOOGLE_APPLICATION_CREDENTIALS=$CRED_PATH/$creds
        export GOOGLE_CREDENTIALS=$CRED_PATH/$creds
        echo "Active GCP Creds : $creds"
    break
    done
}



function gi() {
    curl -sLw "\n" https://www.toptal.com/developers/gitignore/api/$@ ;
}

function az_login_work {
    export AZURE_CONFIG_DIR=~/.az
    az login --use-device-code
}

function az_login_personal {
    export AZURE_CONFIG_DIR=~/.azpersonal
    az login --use-device-code
}

function getproc {
    local proc=$1
    ps aux |grep -i ${proc}
}

function help {
    local func_name=$1
    case $func_name in
        "lol") echo "lol" ;;
    esac

}


# Darwin
{{- if eq .chezmoi.os "darwin" }}
alias ls="gls --color=auto"

azcli_path=$(gfind "${HOMEBREW_PREFIX}/Cellar/azure-cli" -mindepth 1 -maxdepth 1 -type d)
az_version=${azcli_path/${HOMEBREW_PREFIX}\/Cellar\/azure-cli\//}
source ${HOMEBREW_PREFIX}/Cellar/azure-cli/${az_version}/etc/bash_completion.d/az

plop() {
        plop=$(mktemp --directory -t '-plop' -p /var/tmp)
        cd $plop
}

{{- end }}

# Linux
{{- if eq .chezmoi.os "linux" }}
plop() {
        plop=$(mktemp --directory --suffix '-plop' -p /var/tmp)
        cd $plop
}
{{- end }}
